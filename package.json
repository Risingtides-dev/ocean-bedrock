{
  "name": "ocean-bedrock",
  "version": "0.1.0",
  "description": "Cloud-box substrate for Ocean Longhouse support: authenticated shared files, context ingest, ledger, and knowledge-layer bootstrap.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node src/server.mjs",
    "dev": "OCEAN_BEDROCK_BOOTSTRAP_TOKEN=dev-token-change-me node src/server.mjs",
    "token:create": "node scripts/issue-token.mjs",
    "ocean:bootstrap": "node scripts/ocean-bootstrap.mjs",
    "ocean:ingest": "node scripts/ocean-ingest-local.mjs",
    "ocean:app": "node scripts/ocean-local-app.mjs",
    "ocean:worker": "node scripts/ocean-ingest-worker.mjs",
    "mcp": "node scripts/ocean-bedrock-mcp.mjs",
    "db:check": "node scripts/check-postgres.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "pg": "^8.21.0"
  }
}
